{
  "name": "astroyou",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "pnpm run test:types && pnpm run test:functions",
    "test:types": "tsc -p tsconfig.app.json --noEmit",
    "test:functions": "rm -rf node_modules/.tmp/functions-tests && tsc -p tsconfig.functions-test.json && node scripts/run-function-tests.mjs",
    "build": "tsc -b && vite build && node scripts/prerender-seo-pages.mjs",
    "lint": "eslint .",
    "check:launch": "node scripts/check-launch-readiness.mjs",
    "check:services": "node scripts/verify-live-services.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@netlify/functions": "^5.3.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/three": "^0.184.1",
    "firebase": "^12.14.0",
    "firebase-admin": "^14.0.0",
    "framer-motion": "^12.40.0",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.17.0",
    "razorpay": "^2.9.6",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "remark-gfm": "^4.0.1",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
