rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User documents — only owner can read/write ──────────────────
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // Allow creating own document with initial credits of 15
      allow create: if request.auth != null && request.auth.uid == userId
                    && request.resource.data.credits == 15;

      // Allow updating own document with credit restrictions
      // Credits can only decrease by exactly 1 (usage) or stay unchanged (profile edits)
      // Credit increases (purchases) are handled server-side via Admin SDK
      allow update: if request.auth != null && request.auth.uid == userId
                    && (
                      // Credits not being changed
                      request.resource.data.credits == resource.data.credits
                      // OR credits decremented by exactly 1, staying >= 0
                      || (request.resource.data.credits == resource.data.credits - 1
                          && request.resource.data.credits >= 0)
                      // OR credits being initialized (field didn't exist before)
                      || (!('credits' in resource.data) && request.resource.data.credits == 15)
                    );

      // Chats subcollection
      match /chats/{chatId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Messages subcollection within chats
        match /messages/{messageId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      // Consultations subcollection
      match /consultations/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Consultation reviews subcollection
      match /consultations_reviews/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Friends / inner circle subcollection
      match /friends/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Referrals subcollection
      match /referrals/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ── Shared astronomical data — authenticated read, server-only write ─
    match /panchang/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }

    match /transit_reports/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }

    // ── OTP collection — server-only (no client access) ──────────────
    match /otps/{email} {
      allow read, write: if false; // Admin SDK only
    }
  }
}
