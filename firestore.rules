rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // ── User documents — only owner can read/write ──────────────────
    match /users/{userId} {
      allow read: if isOwner(userId);

      allow create: if isOwner(userId)
                    && !('subscription' in request.resource.data)
                    && (
                      !('credits' in request.resource.data)
                      || request.resource.data.credits == 15
                    );

      // Money and subscription state are server-owned through Admin SDK.
      // Explicit field equality is more robust than diff().affectedKeys(),
      // which only reports top-level keys and is easy to get subtly wrong.
      allow update: if isOwner(userId)
                    && request.resource.data.credits == resource.data.credits
                    && request.resource.data.subscription == resource.data.subscription;

      // Chats subcollection
      match /chats/{chatId} {
        allow read, write: if isOwner(userId);

        // Messages subcollection within chats
        match /messages/{messageId} {
          allow read, write: if isOwner(userId);
        }
      }

      // Consultations are billed server-side. Users can read receipts only.
      match /consultations/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      // Consultation reviews — written server-side only (verifies the session
      // actually happened). Owner may read their own.
      match /consultations_reviews/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      // Server-written review/feedback records. Owner-read, server-write only.
      match /consultationReviews/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
      match /testimonialSubmissions/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
      match /predictionFeedback/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
      match /referralClaims/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
      match /pushTokens/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      match /creditLedger/{entryId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      match /reports/{reportId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      match /digests/{digestId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }

      // Friends / inner circle subcollection
      match /friends/{docId} {
        allow read, write: if isOwner(userId);
      }

      // Referrals — reward grants are server-owned (Admin SDK) to prevent
      // self-referral / reward farming. Owner may read their own.
      match /referrals/{docId} {
        allow read: if isOwner(userId);
        allow write: if false;
      }
    }

    // ── Shared astronomical data — authenticated read, server-only write ─
    match /panchang/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }

    match /transit_reports/{docId} {
      allow read: if request.auth != null;
      allow write: if false; // Admin SDK only
    }

    // ── OTP collection — server-only (no client access) ──────────────
    match /otps/{email} {
      allow read, write: if false; // Admin SDK only
    }

    match /paymentOrders/{docId} {
      allow read, write: if false; // Admin SDK only
    }

    match /auditLogs/{docId} {
      allow read, write: if false; // Admin SDK only
    }

    match /rateLimits/{docId} {
      allow read, write: if false; // Admin SDK only
    }

    match /webhookEvents/{docId} {
      allow read, write: if false; // Admin SDK only
    }

    // ── Default-deny catch-all ───────────────────────────────────────
    // Any collection not explicitly matched above (analyticsEvents,
    // expertApplications, supportTickets, remedyRequests, trustModerationQueue,
    // predictionFeedbackAggregateQueue, astrologers, healthchecks, …) is
    // server-only. This is defense-in-depth on top of Firestore's implicit
    // default-deny, so a future console edit can't silently open them.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
